# Скопируйте этот файл в _bot/.env и заполните своими значениями.
# .env НЕ коммитится (см. .gitignore) — секреты остаются только на сервере.

# --- LLM (модель для сводок) ---
LLM_API_KEY=sk-ВАШ_КЛЮЧ
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5-mini
# Gemini (OpenAI-совместимый): LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai , LLM_MODEL=gemini-2.5-flash
# Другой провайдер — поставьте его base_url и имя модели.

# --- Telegram (тот же бот, что у мониторинга) ---
TELEGRAM_BOT_TOKEN=123456789:AA-ВАШ_ТОКЕН
TELEGRAM_CHAT_ID=ВАШ_CHAT_ID
# личный чат: число вида 123456789 ; канал: вида -100xxxxxxxxxx

# --- Репозиторий базы знаний на сервере ---
REPO_DIR=/home/user/ai-knowledge
